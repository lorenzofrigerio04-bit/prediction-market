{
  "buildCommand": "prisma generate && next build",
  "framework": "nextjs",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/run-football-engine",
      "schedule": "0 */8 * * *"
    },
    {
      "path": "/api/cron/resolve-sport-events",
      "schedule": "*/30 * * * *"
    }
  ]
}
