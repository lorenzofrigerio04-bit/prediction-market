generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(cuid())
  email         String?         @unique
  name          String?
  emailVerified DateTime?       @map("email_verified")
  image         String?
  password      String?
  role          String?         @default("USER")
  streakCount   Int             @default(0) @map("streak_count")
  credits       Int             @default(100)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  totalEarned   Int             @default(0) @map("total_earned")
  creditsMicros BigInt          @default(0) @map("credits_micros")
  accounts      Account[]
  reactions     Reaction[]
  comments      Comment[]
  eventFollows  EventFollower[]
  events        Event[]         @relation("EventCreator")
  notifications Notification[]
  oracleChats   OracleChat[]
  Position      Position[]
  postComments  PostComment[]
  postLikes     PostLike[]
  posts         Post[]
  Prediction    Prediction[]
  Trade         Trade[]
  Transaction   Transaction[]
  userBadges    UserBadge[]
  userMissions  UserMission[]
  userXP        UserXP?
  sessions      Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  data      String?
  message   String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, readAt])
  @@index([createdAt])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  payload    String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

model PipelineRun {
  id                    String    @id @default(cuid())
  runId                 String    @unique @map("run_id")
  startedAt             DateTime  @default(now()) @map("started_at")
  completedAt           DateTime? @map("completed_at")
  dryRun                Boolean   @default(false) @map("dry_run")
  source                String
  eligibleCount         Int       @map("eligible_count")
  candidatesCount       Int       @map("candidates_count")
  rulebookValidCount    Int       @map("rulebook_valid_count")
  rulebookRejectedCount Int       @map("rulebook_rejected_count")
  dedupedCount          Int       @map("deduped_count")
  selectedCount         Int       @map("selected_count")
  createdCount          Int       @map("created_count")
  skippedCount          Int       @map("skipped_count")
  reasonsCount          Json?     @map("reasons_count")
  eventIds              String[]  @map("event_ids")
  avgQualityScore       Float?    @map("avg_quality_score")
  errorMessage          String?   @map("error_message")

  @@index([startedAt])
  @@map("pipeline_runs")
}

model EventSubmission {
  id               String    @id @default(cuid())
  title            String
  description      String?
  category         String
  closesAt         DateTime
  resolutionSource String?
  submittedById    String
  status           String    @default("PENDING")
  reviewedAt       DateTime?
  reviewedById     String?
  reviewNotes      String?
  eventId          String?
  notifyPhone      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([submittedById])
  @@index([status])
  @@index([createdAt])
  @@map("event_submissions")
}

model Event {
  id                        String                     @id @default(cuid())
  title                     String
  description               String?
  category                  String
  closesAt                  DateTime
  resolutionSourceUrl       String?
  resolutionNotes           String?
  createdById               String
  resolved                  Boolean                    @default(false)
  resolvedAt                DateTime?
  outcome                   String?
  probability               Float?
  yesCredits                Int?
  noCredits                 Int?
  totalCredits              Int?
  yesPredictions            Int?
  noPredictions             Int?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @default(now()) @updatedAt
  p_init                    Float?
  b                         Float
  q_yes                     Float?
  q_no                      Float?
  realWorldEventTime        DateTime?
  resolutionTimeExpected    DateTime?
  resolutionBufferHours     Int                        @default(24)
  resolutionStatus          String                     @default("PENDING")
  status                    String                     @default("OPEN")
  dedupKey                  String                     @unique
  resolutionAuthorityHost   String?
  resolutionAuthorityType   String?
  resolutionCriteriaYes     String?
  resolutionCriteriaNo      String?
  sourceStorylineId         String?
  templateId                String?
  tradingMode               String                     @default("AMM") @map("trading_mode")
  sourceType                String?                    @map("source_type")
  oddsApiEventId            String?                    @map("odds_api_event_id")
  bestBookmakerKey          String?                    @map("best_bookmaker_key")
  bestBookmakerTitle        String?                    @map("best_bookmaker_title")
  bestYesOdds               Float?                     @map("best_yes_odds")
  bestNoOdds                Float?                     @map("best_no_odds")
  marketId                  String?                    @unique @map("market_id")
  timezone                  String                     @default("Europe/Rome")
  resolutionSourceSecondary String?                    @map("resolution_source_secondary")
  resolutionSourceTertiary  String?                    @map("resolution_source_tertiary")
  resolutionCriteria        String?                    @map("resolution_criteria")
  edgeCasePolicyRef         String?                    @map("edge_case_policy_ref")
  generatorVersion          String?                    @map("generator_version")
  generationScores          Json?                      @map("generation_scores")
  creationMetadata          Json?                      @map("creation_metadata")
  imageUrl                  String?                    @map("image_url")
  imagePrompt               String?                    @map("image_prompt")
  imageStyle                String?                    @map("image_style")
  imageSeedOrRequestId      String?                    @map("image_seed_or_request_id")
  imageAltText              String?                    @map("image_alt_text")
  imageGenerationStatus     String                     @default("PENDING") @map("image_generation_status")
  imageProvider             String?                    @map("image_provider")
  imageVersion              String?                    @map("image_version")
  imageBrief                Json?                      @map("image_brief")
  imageProviderMetadata     Json?                      @map("image_provider_metadata")
  resolutionDisputedAt      DateTime?
  resolutionDisputedBy      String?
  hidden                    Boolean                    @default(false)
  marketType                String                     @default("BINARY") @map("market_type")
  outcomes                  Json?                      @map("outcomes")
  scalarConfig              Json?                      @map("scalar_config")
  footballDataMatchId       Int?                       @map("football_data_match_id")
  matchStatus               String?                    @map("match_status")
  ammState                  AmmState?
  comments                  Comment[]
  followers                 EventFollower[]
  probabilitySnapshots      EventProbabilitySnapshot[]
  createdBy                 User                       @relation("EventCreator", fields: [createdById], references: [id])
  Position                  Position[]
  posts                     Post[]
  Prediction                Prediction[]
  Trade                     Trade[]

  @@index([createdById])
  @@index([closesAt])
  @@index([resolved])
  @@index([category])
  @@index([status])
  @@index([dedupKey])
  @@index([sourceStorylineId])
  @@index([tradingMode])
  @@index([sourceType])
  @@index([oddsApiEventId])
  @@index([imageGenerationStatus])
  @@index([generatorVersion])
  @@index([marketType])
  @@index([hidden], map: "idx_events_hidden")
  @@map("events")
}

model EventProbabilitySnapshot {
  id        String   @id @default(cuid())
  eventId   String   @map("event_id")
  yesPct    Float    @map("yes_pct")
  createdAt DateTime @default(now()) @map("created_at")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
  @@map("event_probability_snapshots")
}

model Comment {
  id        String     @id @default(cuid())
  eventId   String
  userId    String
  parentId  String?
  content   String
  hidden    Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  reactions Reaction[]
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  parent    Comment?   @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[]  @relation("CommentReplies")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([userId])
  @@index([parentId])
  @@index([hidden])
  @@index([createdAt])
  @@map("comments")
}

model Reaction {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  type      String
  createdAt DateTime @default(now())
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, type])
  @@index([commentId])
  @@index([userId])
  @@map("comment_reactions")
}

model Prediction {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  outcome   String
  amount    Int      @default(0)
  credits   Int
  won       Boolean?
  payout    Int?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@index([resolved])
  @@index([createdAt])
  @@map("predictions")
}

model AmmState {
  id         String   @id @default(cuid())
  eventId    String   @unique @map("event_id")
  qYesMicros BigInt   @map("q_yes_micros")
  qNoMicros  BigInt   @map("q_no_micros")
  bMicros    BigInt   @map("b_micros")
  version    Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("amm_state")
}

model Position {
  id             String   @id @default(cuid())
  eventId        String   @map("event_id")
  userId         String   @map("user_id")
  yesShareMicros BigInt   @default(0) @map("yes_share_micros")
  noShareMicros  BigInt   @default(0) @map("no_share_micros")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@map("positions")
}

model Trade {
  id               String   @id @default(cuid())
  eventId          String   @map("event_id")
  userId           String   @map("user_id")
  side             String
  outcome          String
  shareMicros      BigInt   @map("share_micros")
  costMicros       BigInt   @map("cost_micros")
  idempotencyKey   String   @map("idempotency_key")
  createdAt        DateTime @default(now())
  realizedPlMicros BigInt?  @map("realized_pl_micros")
  event            Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, idempotencyKey])
  @@index([eventId])
  @@index([userId])
  @@index([createdAt])
  @@map("trades")
}

model Transaction {
  id            String   @id @default(cuid())
  userId        String
  type          String
  amount        Int
  referenceId   String?
  createdAt     DateTime @default(now())
  amountMicros  BigInt?  @map("amount_micros")
  referenceType String?  @map("reference_type")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("transactions")
}

model Badge {
  id          String      @id @default(cuid())
  name        String
  description String
  icon        String
  rarity      String
  criteria    String?
  createdAt   DateTime    @default(now())
  code        String?   @unique
  effect      String?
  userBadges  UserBadge[]

  @@index([rarity])
  @@map("badges")
}

model UserBadge {
  id         String   @id @default(cuid())
  userId     String
  badgeId    String
  unlockedAt DateTime @default(now())
  badge      Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
  @@map("user_badges")
}

model VerificationToken {
  token      String   @id
  identifier String
  expires    DateTime

  @@index([identifier])
  @@index([expires])
  @@map("verification_tokens")
}

model EventFollower {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
  @@index([createdAt])
  @@map("event_followers")
}

model Post {
  id           String        @id @default(cuid())
  userId       String        @map("user_id")
  eventId      String        @map("event_id")
  content      String?
  type         PostType
  aiImageUrl   String?       @map("ai_image_url")
  source       PostSource
  hidden       Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  postComments PostComment[]
  postLikes    PostLike[]
  event        Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventId])
  @@index([createdAt])
  @@index([hidden])
  @@map("posts")
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("post_likes")
}

model PostComment {
  id        String        @id @default(cuid())
  postId    String        @map("post_id")
  userId    String        @map("user_id")
  parentId  String?       @map("parent_id")
  content   String
  hidden    Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  parent    PostComment?  @relation("PostCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   PostComment[] @relation("PostCommentReplies")
  post      Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
  @@index([parentId])
  @@index([createdAt])
  @@index([hidden])
  @@map("post_comments")
}

model Mission {
  id           String        @id @default(cuid())
  name         String
  description  String
  type         String
  target       Int
  reward       Int
  period       String
  category     String?
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  userMissions UserMission[]

  @@index([period])
  @@index([active])
  @@map("missions")
}

model MissionTemplate {
  id             String        @id @default(cuid())
  code           String        @unique
  title          String
  description    String
  type           String
  category       String
  difficulty     String
  chapterLevel   Int?
  progressMetric String
  targetValue    Int
  constraints    String?
  rewards        String
  isActive       Boolean       @default(true)
  sortOrder      Int?
  createdAt      DateTime      @default(now())
  userMissions   UserMission[]

  @@index([type])
  @@index([isActive])
  @@index([chapterLevel])
  @@map("mission_templates")
}

model UserXP {
  id           String   @id @default(cuid())
  userId       String   @unique
  xpTotal      Int      @default(0)
  currentLevel Int      @default(1)
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_xp")
}

model UserMission {
  id                String           @id @default(cuid())
  userId            String
  periodStart       DateTime
  progress          Int              @default(0)
  completed         Boolean          @default(false)
  completedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  missionTemplateId String?          @map("mission_template_id")
  progressValue     Int              @default(0) @map("progress_value")
  targetValue       Int?             @map("target_value")
  status            String           @default("ACTIVE")
  expiresAt         DateTime?        @map("expires_at")
  metadata          String?
  claimedAt         DateTime?        @map("claimed_at")
  missionId         String?
  mission           Mission?         @relation(fields: [missionId], references: [id], onDelete: Cascade)
  missionTemplate   MissionTemplate? @relation(fields: [missionTemplateId], references: [id], onDelete: Cascade)
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, missionId, periodStart])
  @@unique([userId, missionTemplateId, periodStart])
  @@index([userId])
  @@index([missionId])
  @@index([missionTemplateId])
  @@index([periodStart])
  @@index([status])
  @@map("user_missions")
}

model ShopItem {
  id           String   @id @default(cuid())
  name         String
  type         String   @default("CREDIT_BUNDLE")
  priceCredits Int
  description  String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active])
  @@map("shop_items")
}

model Season {
  id        String   @id @default(cuid())
  name      String
  startAt   DateTime
  endAt     DateTime
  createdAt DateTime @default(now())

  @@index([startAt])
  @@index([endAt])
  @@map("seasons")
}

model SourceArticle {
  id           String         @id @default(cuid())
  canonicalUrl String         @unique
  sourceType   String
  sourceId     String?
  title        String
  content      String?
  publishedAt  DateTime?
  fetchedAt    DateTime       @default(now())
  rawData      String
  clusterId    String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  cluster      SourceCluster? @relation(fields: [clusterId], references: [id])

  @@index([sourceType])
  @@index([canonicalUrl])
  @@index([clusterId])
  @@index([fetchedAt])
  @@map("source_articles")
}

model SourceCluster {
  id           String          @id @default(cuid())
  jaccardScore Float
  articleCount Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  articles     SourceArticle[]

  @@index([jaccardScore])
  @@map("source_clusters")
}

model IngestionLog {
  id              String   @id @default(cuid())
  sourceType      String
  articlesFetched Int      @default(0)
  articlesNew     Int      @default(0)
  articlesDeduped Int      @default(0)
  clustersCreated Int      @default(0)
  durationMs      Int
  success         Boolean
  errorMessage    String?
  createdAt       DateTime @default(now())

  @@index([sourceType])
  @@index([createdAt])
  @@map("ingestion_logs")
}

model OracleChat {
  id        String         @id @default(cuid())
  userId    String         @map("user_id")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports   OracleReport[]

  @@index([userId])
  @@map("oracle_chats")
}

model OracleReport {
  id         String     @id @default(cuid())
  chatId     String     @map("chat_id")
  userQuery  String     @map("user_query")
  reportText String     @map("report_text")
  topic      String?
  createdAt  DateTime   @default(now())
  chat       OracleChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@map("oracle_reports")
}

enum PostType {
  SLIDE
  AI_IMAGE
}

enum PostSource {
  CREATED_BY_ME
  REPOST
  BOT
}
