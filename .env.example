# Database (PostgreSQL). Neon: usare la connection string CON pooler (es. ...-pooler....neon.tech/neondb?sslmode=require).
# Per i comandi Prisma da terminale (db push, migrate) serve anche in .env se usi solo .env.local per Next.
DATABASE_URL=

# Auth (NextAuth). Per Login con Google: NEXTAUTH_URL, NEXTAUTH_SECRET, GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET.
# NEXTAUTH_URL è richiesto in prod per callback OAuth e per il trigger in background delle immagini AI (feed).
# Solo sviluppo: se vedi "unable to get local issuer certificate" con Google, imposta NEXTAUTH_INSECURE_SSL_DEV=1 (e riavvia).
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_INSECURE_SSL_DEV=1

# Cron: secret per autenticare le chiamate cron (Vercel). In prod impostare CRON_SECRET.
# CRON_SECRET=

# Disabilita generazione eventi (cron + admin). Quando true: nessun nuovo evento generato.
# DISABLE_EVENT_GENERATION=true

# Disabilita tutte le chiamate OpenAI (Oracle, immagini AI, commenti bot, AI Event Generator).
# DISABLE_OPENAI=true

# Disabilita solo la generazione immagini AI (feed e market). Le card usano le immagini di sfondo per categoria.
# DISABLE_AI_IMAGE_GENERATION=true

# Disabilita tutti i cron automatici (generate-events, generate-odds-events, generate-post-images, generate-market-images).
# Gli unici eventi generati saranno quelli lanciati manualmente da dashboard admin (Esegui generazione eventi).
# DISABLE_CRON_AUTOMATION=true

# Attività simulata (bot: previsioni, commenti, reazioni, follow, post nel feed).
# Per FERMARE i bot: imposta DISABLE_SIMULATED_ACTIVITY=true oppure non impostare ENABLE_SIMULATED_ACTIVITY.
# DISABLE_SIMULATED_ACTIVITY=true
# Per abilitare i bot (cron / pulsante Admin): ENABLE_SIMULATED_ACTIVITY=true
# ENABLE_SIMULATED_ACTIVITY=true

# Ingestion (cron generate-events esegue ingest prima della pipeline se abilitato)
INGESTION_ENABLED=true
# Se true, generate-events fallisce se l'ingest fallisce; default: log e continua
# GENERATE_EVENTS_REQUIRE_INGEST=false

# DEPRECATED / NO-OP: manual submit is always MDE-only; legacy path and fallback removed.
# MDE_AUTHORITATIVE_MANUAL_SUBMIT=

# MDE validation: when true, failing MDE shadow validation blocks immediate publish (submission goes PENDING).
# MDE_ENFORCE_VALIDATION=false
# DEPRECATED / ROLLBACK DISABLED: runPipelineV2 always delegates to runEventGenV2Pipeline; legacy branch no longer active.
# ENABLE_LEGACY_PIPELINE_V2=

# Event Gen v2.0: unico metodo di generazione eventi (sempre attivo). Variabile deprecata.
# EVENT_GEN_V2=true
# CANDIDATE_EVENT_GEN: when true (with EVENT_GEN_V2), use TrendObjects from Trend Detection instead of storylines
# CANDIDATE_EVENT_GEN=false
# USE_DISCOVERY_BACKED_PIPELINE: when true, use discovery-backed path (fonti ANSA/AGI/ISTAT ecc. → MDE → eventi). Gli eventi creati hanno sourceType=NEWS e compaiono in Home/Esplora. Se false, la pipeline usa storyline/trend e spesso crea 0 eventi.
# USE_DISCOVERY_BACKED_PIPELINE=true
# AI Event Generator: when true (with CANDIDATE_EVENT_GEN), use AI instead of templates for event generation
# AI_EVENT_GENERATOR=false
# Psychological Title Engine: when true (with CANDIDATE_EVENT_GEN), transform titles to engaging English format
# PSYCHOLOGICAL_TITLE_ENGINE=false

# Trend Detection Engine v2: when true, reorder storylines by trend_score from Trend Radar
# TREND_RADAR_V2=false
# Trend cache TTL in seconds (default 900 = 15 min)
# TREND_CACHE_TTL_SEC=900

# Debug flags
STORYLINE_DEBUG=false
EVENT_GEN_DEBUG=false
PIPELINE_DEBUG=false
# Structured JSON logs for pipeline observability (runId, stage, payload)
# PIPELINE_STRUCTURED_LOG=false

# Storyline parameters
STORYLINE_MIN_SIGNALS=3
STORYLINE_MAX_AGE_HOURS=72
STORYLINE_MIN_MOMENTUM=15
STORYLINE_MIN_NOVELTY=20
# Minuti entro cui considerare "notizie nuove" (fetch articoli): se ci sono storyline con fetch negli ultimi N min, si usano solo quelle; altrimenti si usano tutte (escluse quelle già pubblicate). Default 30. 0 = disabilita preferenza.
# STORYLINE_FRESHNESS_MINUTES=30

# Event generation parameters (più alti = più eventi per run; con multi-outcome più notizie diventano mercati)
TARGET_OPEN_EVENTS=30
MAX_NEW_PER_RUN=25
CATEGORY_CAP_DEFAULT=10
MAX_EVENTS_PER_STORYLINE=3

# Quality scoring and diversity
QUALITY_THRESHOLD=0.75
DIVERSITY_WEIGHT=0.15
# Discovery-backed: con USE_DISCOVERY_BACKED_PIPELINE=true i candidati MDE usano soglia QUALITY_THRESHOLD_DISCOVERY (default 0.55) invece di 0.75, così selectedCount > 0. Opzionale: ENABLE_DISCOVERY_RELAXED_SELECTION=true per abilitare anche senza pipeline discovery.
# QUALITY_THRESHOLD_DISCOVERY=0.55

# NewsAPI (optional - ingestion funziona anche senza)
NEWSAPI_API_KEY=
# Use eventregistry.org base URL instead of api.newsapi.ai
# NEWSAPI_USE_EVENT_REGISTRY=false

# The Odds API (optional - per mostrare quote bookmaker sugli eventi matchabili)
# ODDS_API_KEY=

# football-data.org (calendario partite e risultati per risoluzione automatica – pagina Sport / Calcio).
# https://www.football-data.org — token obbligatorio (free: 10 req/min, 12 competizioni).
FOOTBALL_DATA_ORG_API_TOKEN=

# Discovery sources (event-gen discovery-backed pipeline). Optional; default URLs used when not set.
# DISCOVERY_PROTEZIONE_CIVILE_RSS_URL=
# DISCOVERY_AGI_RSS_URL=
# DISCOVERY_INGV_TERREMOTI_URL=
# DISCOVERY_ISTAT_SDMX_URL=
# DISCOVERY_WIKIMEDIA_PAGEVIEWS_URL=
# DISCOVERY_GOOGLE_TRENDS_IT_URL=
# YouTube Data API (for discovery source youtube-data-it)
# YOUTUBE_API_KEY=
# Google Trends (for discovery source google-trends-it; URL may come from DISCOVERY_GOOGLE_TRENDS_IT_URL)
# GOOGLE_TRENDS_API_KEY=

# Generazione immagini AI per feed (Step 9). OPENAI_API_KEY usata anche per immagini e titoli AI.
OPENAI_API_KEY=
BLOB_READ_WRITE_TOKEN=
# Titolo evento (domanda): tutti i path (admin, storyline, discovery, trend) passano dal Psychological Title Engine.
# Se USE_AI_TITLE_GENERATION=true l'LLM riscrive ogni titolo nella migliore versione per prediction market; altrimenti solo normalizzazione (lunghezza, "?").
# USE_AI_TITLE_GENERATION=true
# Massimo chiamate LLM titolo per run (default 20). Solo se USE_AI_TITLE_GENERATION=true; oltre questo numero si usa solo normalizzazione.
# OPENAI_MAX_TITLE_CALLS_PER_RUN=20
# Modello per titolo (default gpt-4o-mini).
# AI_TITLE_MODEL=gpt-4o-mini
# Modello immagini (default: gpt-image-1.5). Altri: gpt-image-1, gpt-image-1-mini, dall-e-3.
# AI_IMAGE_MODEL=gpt-image-1.5
# Retry: max tentativi (default 3), delay base ms (default 1000), fallback style preset (default minimal_iconic)
# AI_IMAGE_MAX_RETRIES=3
# AI_IMAGE_RETRY_DELAY_MS=1000
# AI_IMAGE_FALLBACK_STYLE_PRESET=minimal_iconic
